{
  "__inputs": [
    {
      "name": "DS_NURAOS",
      "label": "NuraOS",
      "description": "Prometheus-compatible scrape endpoint at http://<gateway>:8080/metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "description": "NuraOS system observability dashboard - gateway, inference, storage, network, entropy",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Gateway",
      "type": "row"
    },
    {
      "datasource": "${DS_NURAOS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": "${DS_NURAOS}",
          "expr": "rate(nura_gateway_requests_total[1m])",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "title": "Request rate by endpoint (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_NURAOS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": "${DS_NURAOS}",
          "expr": "rate(nura_gateway_rate_limited_total[1m])",
          "legendFormat": "rate limited/s",
          "refId": "A"
        }
      ],
      "title": "Rate-limited requests",
      "type": "stat"
    },
    {
      "datasource": "${DS_NURAOS}",
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": "${DS_NURAOS}",
          "expr": "rate(nura_gateway_chat_latency_microseconds_total[1m]) / rate(nura_gateway_chat_requests_completed_total[1m]) / 1e6",
          "legendFormat": "avg /chat latency",
          "refId": "A"
        }
      ],
      "title": "Average /chat latency",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 10,
      "title": "Inference",
      "type": "row"
    },
    {
      "datasource": "${DS_NURAOS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 11,
      "targets": [
        {
          "datasource": "${DS_NURAOS}",
          "expr": "rate(nura_agent_tokens_in_total[1m])",
          "legendFormat": "tokens in/s",
          "refId": "A"
        },
        {
          "datasource": "${DS_NURAOS}",
          "expr": "rate(nura_agent_tokens_out_total[1m])",
          "legendFormat": "tokens out/s",
          "refId": "B"
        }
      ],
      "title": "Agent token throughput (tokens/s)",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_NURAOS}",
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 12,
      "targets": [
        {
          "datasource": "${DS_NURAOS}",
          "expr": "nura_cgroup_memory_bytes{service=\"llama-server\"}",
          "legendFormat": "llama-server memory",
          "refId": "A"
        },
        {
          "datasource": "${DS_NURAOS}",
          "expr": "nura_cgroup_memory_max_bytes{service=\"llama-server\"}",
          "legendFormat": "llama-server limit",
          "refId": "B"
        }
      ],
      "title": "Inference memory (llama-server cgroup)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 20,
      "title": "Cgroup CPU",
      "type": "row"
    },
    {
      "datasource": "${DS_NURAOS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "id": 21,
      "targets": [
        {
          "datasource": "${DS_NURAOS}",
          "expr": "rate(nura_cgroup_cpu_usage_seconds_total[1m])",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "CPU usage per service cgroup (seconds/s)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 30,
      "title": "Storage",
      "type": "row"
    },
    {
      "datasource": "${DS_NURAOS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.75 }, { "color": "red", "value": 0.90 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 28 },
      "id": 31,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal" },
      "targets": [
        {
          "datasource": "${DS_NURAOS}",
          "expr": "nura_disk_used_percent / 100",
          "legendFormat": "/data",
          "refId": "A"
        }
      ],
      "title": "/data disk usage",
      "type": "gauge"
    },
    {
      "datasource": "${DS_NURAOS}",
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 28 },
      "id": 32,
      "targets": [
        {
          "datasource": "${DS_NURAOS}",
          "expr": "nura_disk_total_bytes",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "datasource": "${DS_NURAOS}",
          "expr": "nura_disk_used_bytes",
          "legendFormat": "used",
          "refId": "B"
        },
        {
          "datasource": "${DS_NURAOS}",
          "expr": "nura_disk_available_bytes",
          "legendFormat": "available",
          "refId": "C"
        }
      ],
      "title": "/data filesystem bytes",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 40,
      "title": "Network",
      "type": "row"
    },
    {
      "datasource": "${DS_NURAOS}",
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "id": 41,
      "targets": [
        {
          "datasource": "${DS_NURAOS}",
          "expr": "rate(nura_net_rx_bytes_total[1m])",
          "legendFormat": "rx {{interface}}",
          "refId": "A"
        },
        {
          "datasource": "${DS_NURAOS}",
          "expr": "rate(nura_net_tx_bytes_total[1m])",
          "legendFormat": "tx {{interface}}",
          "refId": "B"
        }
      ],
      "title": "Network throughput (bytes/s)",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_NURAOS}",
      "fieldConfig": { "defaults": { "unit": "pps", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "id": 42,
      "targets": [
        {
          "datasource": "${DS_NURAOS}",
          "expr": "rate(nura_net_rx_drop_total[1m])",
          "legendFormat": "rx drop {{interface}}",
          "refId": "A"
        },
        {
          "datasource": "${DS_NURAOS}",
          "expr": "rate(nura_net_tx_drop_total[1m])",
          "legendFormat": "tx drop {{interface}}",
          "refId": "B"
        }
      ],
      "title": "Network drops (pkts/s)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "id": 50,
      "title": "Provider Health",
      "type": "row"
    },
    {
      "datasource": "${DS_NURAOS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "closed" }, "1": { "text": "half-open" }, "2": { "text": "open" } } }]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 44 },
      "id": 51,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal" },
      "targets": [
        {
          "datasource": "${DS_NURAOS}",
          "expr": "nura_provider_circuit_breaker_state",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "title": "Provider circuit breaker state",
      "type": "stat"
    },
    {
      "datasource": "${DS_NURAOS}",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 44 },
      "id": 52,
      "targets": [
        {
          "datasource": "${DS_NURAOS}",
          "expr": "rate(nura_provider_probe_success_total[5m])",
          "legendFormat": "success {{provider}}",
          "refId": "A"
        },
        {
          "datasource": "${DS_NURAOS}",
          "expr": "rate(nura_provider_probe_failure_total[5m])",
          "legendFormat": "failure {{provider}}",
          "refId": "B"
        }
      ],
      "title": "Provider probe success/failure rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 },
      "id": 60,
      "title": "Security",
      "type": "row"
    },
    {
      "datasource": "${DS_NURAOS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short",
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 64 }, { "color": "green", "value": 256 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 49 },
      "id": 61,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": "${DS_NURAOS}",
          "expr": "nura_entropy_avail_bits",
          "legendFormat": "entropy bits",
          "refId": "A"
        }
      ],
      "title": "Kernel entropy available (bits)",
      "type": "stat"
    },
    {
      "datasource": "${DS_NURAOS}",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 18, "x": 6, "y": 49 },
      "id": 62,
      "targets": [
        {
          "datasource": "${DS_NURAOS}",
          "expr": "nura_entropy_avail_bits",
          "legendFormat": "entropy bits",
          "refId": "A"
        }
      ],
      "title": "Entropy trend",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 38,
  "tags": ["nuraos", "system", "inference"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_NURAOS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NuraOS System",
  "uid": "nuraos-system-v1",
  "version": 1
}
