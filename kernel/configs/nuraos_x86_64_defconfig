# NuraOS x86-64 kernel config fragment
# Applied on top of tinyconfig via scripts/kernel-config.sh.
# Only options that differ from tinyconfig (or must be explicitly set) appear here.
# Use kernel-config.sh to merge this fragment and produce a full .config.

# ----- Architecture basics -----
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_NR_CPUS=4

# ----- Binary format -----
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# ----- Virtual filesystems -----
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# ----- Persistent storage -----
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y

# ----- Initramfs / initrd -----
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_RD_GZIP=y
CONFIG_RD_XZ=y

# ----- Serial console -----
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_VT=n

# ----- Printk -----
CONFIG_PRINTK=y
CONFIG_EARLY_PRINTK=y

# ----- virtio block -----
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_SCSI=n

# ----- Networking -----
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_IPV6=n
CONFIG_NETFILTER=n
CONFIG_NET_9P=n

# ----- Block layer -----
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y

# ----- PCI -----
CONFIG_PCI=y
CONFIG_PCI_MSI=y

# ----- Clock / timer -----
CONFIG_HZ_250=y
CONFIG_POSIX_TIMERS=y

# ----- Modules: disabled -----
CONFIG_MODULES=n

# ----- Kernel hardening (Phase 40) -----
# Memory: enforce R^X on kernel text and data pages.
CONFIG_STRICT_KERNEL_RWX=y

# KASLR: disabled for CI QEMU TCG compatibility.
# CONFIG_RANDOMIZE_BASE requires PIE relocation; the decompressor's relocation
# code path interacts poorly with QEMU TCG accel + direct -kernel boot, causing
# a silent pre-serial panic before parse_early_param() runs.  Re-enable once
# the base boot is verified green.
CONFIG_RANDOMIZE_BASE=n
CONFIG_RANDOMIZE_MEMORY=n

# Stack: add a strong per-function canary (GCC -fstack-protector-strong).
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y

# Compiler fortification: replace unsafe string ops with checked versions.
CONFIG_FORTIFY_SOURCE=y

# Heap: harden slab freelist linkage and validate copies at every boundary.
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_HARDENED_USERCOPY=y

# Init memory to zero on alloc to reduce uninitialized-read leaks.
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y

# Shuffle page allocator free-list to randomize heap layout.
CONFIG_SHUFFLE_PAGE_ALLOCATOR=y

# Spectre / Meltdown mitigations: retpoline + microcode-based barriers.
CONFIG_RETPOLINE=y
CONFIG_CPU_IBPB_ENTRY=y

# Seccomp: allow processes to install BPF syscall filters (used by gateway).
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# Disable /proc/kcore and restrict dmesg to privileged processes.
CONFIG_PROC_KCORE=n
CONFIG_SECURITY_DMESG_RESTRICT=y

# Namespace support: enable IPC, UTS, PID, mount, and network namespaces for
# per-service isolation. User namespaces remain disabled (no container use case).
CONFIG_NAMESPACES=y
CONFIG_IPC_NS=y
CONFIG_UTS_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=n

# Cgroup v2 (unified hierarchy) for per-service resource control (Phase 71).
# The manager places each service in a slice cgroup with cpu/memory/io limits.
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_FREEZER=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=n
CONFIG_BLKCG=y
CONFIG_CGROUP_PIDS=y

# Hardware RNG: virtio-rng provides host entropy to the guest via the virtio bus.
# This seeds the kernel CSPRNG very early in boot, before any crypto operations.
# Required for good entropy in QEMU where the guest has no hardware entropy source.
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y

# nftables: netfilter packet filtering for default-deny firewall (Phase 79).
# NF_CONNTRACK tracks connection state (established/related accept rules).
# NF_TABLES_INET applies rules to both IPv4 and IPv6 at once.
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_CT=y
CONFIG_NFT_COUNTER=y
CONFIG_NFT_LOG=y
CONFIG_NFT_REJECT=y
CONFIG_NFT_REJECT_INET=y
CONFIG_NF_REJECT_IPV4=y
CONFIG_NF_REJECT_IPV6=y

# CPU frequency scaling for inference performance profiles (Phase 77).
# performance governor: pins all CPUs at maximum frequency; lowest latency
# for inference token generation at the cost of higher power draw.
# ondemand governor: scales frequency on demand; lower average power, slightly
# higher first-token latency due to ramp-up time.
# x86_acpi_cpufreq: exposes host P-states to the KVM guest via ACPI.
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_STAT=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
CONFIG_X86_ACPI_CPUFREQ=y
CONFIG_CPU_IDLE=y
CONFIG_CPU_IDLE_GOV_LADDER=y
CONFIG_CPU_IDLE_GOV_MENU=y

# ACPI: power management and hardware events (Phase 76).
# CONFIG_ACPI_BUTTON enables the power-button driver; pressing the QEMU power
# button generates an ACPI event that the kernel translates to SIGPWR delivered
# to PID 1 (nura-manager). This drives the ordered shutdown path.
CONFIG_ACPI=y
CONFIG_ACPI_BUTTON=y

# Linux Security Module: Landlock for per-service filesystem confinement (Phase 72).
# Landlock (ABI v1, kernel 5.13+) lets each service restrict its own filesystem
# access to a declared allowlist without requiring privileged LSM configuration.
# No AppArmor or SELinux policy authoring is needed; policies live in TOML files.
CONFIG_SECURITY=y
CONFIG_SECURITY_LANDLOCK=y
CONFIG_LSM="landlock"

# Panic on data corruption detected by the kernel.
CONFIG_BUG_ON_DATA_CORRUPTION=y

# ----- Debug: off -----
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_INFO=n
CONFIG_MAGIC_SYSRQ=n
CONFIG_KALLSYMS=n
CONFIG_FTRACE=n

# ----- Misc needed -----
CONFIG_MULTIUSER=y
CONFIG_SHMEM=y
CONFIG_ANON_INODES=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_AIO=y
CONFIG_FILE_LOCKING=y
