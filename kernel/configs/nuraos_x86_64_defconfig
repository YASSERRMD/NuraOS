# NuraOS x86-64 kernel config fragment
# Applied on top of tinyconfig via scripts/kernel-config.sh.
# Only options that differ from tinyconfig (or must be explicitly set) appear here.
# Use kernel-config.sh to merge this fragment and produce a full .config.

# ----- Architecture basics -----
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_NR_CPUS=4

# ----- Binary format -----
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# ----- Virtual filesystems -----
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# ----- Persistent storage -----
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y

# ----- Initramfs / initrd -----
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_RD_GZIP=y
CONFIG_RD_XZ=y

# ----- Serial console -----
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_VT=n

# ----- Printk -----
CONFIG_PRINTK=y
CONFIG_EARLY_PRINTK=y

# ----- virtio block -----
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_SCSI=n

# ----- Networking -----
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_IPV6=n
CONFIG_NETFILTER=n
CONFIG_NET_9P=n

# ----- Block layer -----
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y

# ----- PCI -----
CONFIG_PCI=y
CONFIG_PCI_MSI=y

# ----- Clock / timer -----
CONFIG_HZ_250=y
CONFIG_POSIX_TIMERS=y

# ----- Modules: disabled -----
CONFIG_MODULES=n

# ----- Kernel hardening (Phase 40) -----
# Memory: enforce R^X on kernel text and data pages.
CONFIG_STRICT_KERNEL_RWX=y

# KASLR: randomize kernel load address to frustrate ROP chains.
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y

# Stack: add a strong per-function canary (GCC -fstack-protector-strong).
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y

# Compiler fortification: replace unsafe string ops with checked versions.
CONFIG_FORTIFY_SOURCE=y

# Heap: harden slab freelist linkage and validate copies at every boundary.
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_HARDENED_USERCOPY=y

# Init memory to zero on alloc to reduce uninitialized-read leaks.
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y

# Shuffle page allocator free-list to randomize heap layout.
CONFIG_SHUFFLE_PAGE_ALLOCATOR=y

# Spectre / Meltdown mitigations: retpoline + microcode-based barriers.
CONFIG_RETPOLINE=y
CONFIG_CPU_IBPB_ENTRY=y

# Seccomp: allow processes to install BPF syscall filters (used by gateway).
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# Disable /proc/kcore and restrict dmesg to privileged processes.
CONFIG_PROC_KCORE=n
CONFIG_SECURITY_DMESG_RESTRICT=y

# Disable user namespaces to reduce attack surface (no container use case).
CONFIG_USER_NS=n

# Panic on data corruption detected by the kernel.
CONFIG_BUG_ON_DATA_CORRUPTION=y

# ----- Debug: off -----
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_INFO=n
CONFIG_MAGIC_SYSRQ=n
CONFIG_KALLSYMS=n
CONFIG_FTRACE=n

# ----- Misc needed -----
CONFIG_MULTIUSER=y
CONFIG_SHMEM=y
CONFIG_ANON_INODES=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_AIO=y
CONFIG_FILE_LOCKING=y
