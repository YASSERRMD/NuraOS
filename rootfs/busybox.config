# NuraOS minimal BusyBox configuration
# Applet set: only what the init, networking, and basic inspection need.
# Build fully static against musl via fetch-busybox.sh.

# ----- Build settings -----
CONFIG_STATIC=y
CONFIG_CROSS_COMPILER_PREFIX=""
CONFIG_EXTRA_CFLAGS=""

# ----- Core shell -----
CONFIG_ASH=y
CONFIG_ASH_BASH_COMPAT=n
CONFIG_ASH_IDLE_TIMEOUT=n
CONFIG_ASH_JOB_CONTROL=y
CONFIG_ASH_ALIAS=y
CONFIG_ASH_ECHO=y
CONFIG_ASH_PRINTF=y
CONFIG_ASH_TEST=y
CONFIG_FEATURE_SH_STANDALONE=y

# Disable bash/hush (we only need ash/sh)
CONFIG_BASH=n
CONFIG_HUSH=n

# ----- Init -----
CONFIG_INIT=y
CONFIG_FEATURE_USE_INITTAB=y
CONFIG_FEATURE_INIT_SYSLOG=n
CONFIG_FEATURE_INIT_QUIET=n
CONFIG_HALT=y
CONFIG_POWEROFF=y
CONFIG_REBOOT=y

# ----- Core filesystem utilities -----
CONFIG_CAT=y
CONFIG_ECHO=y
CONFIG_LS=y
CONFIG_MKDIR=y
CONFIG_LN=y
CONFIG_MKNOD=y
CONFIG_CP=y
CONFIG_MV=y
CONFIG_RM=y
CONFIG_CHMOD=y
CONFIG_CHOWN=y
CONFIG_FIND=y
CONFIG_GREP=y
CONFIG_SED=y
CONFIG_SORT=y
CONFIG_WC=y
CONFIG_HEAD=y
CONFIG_TAIL=y

# ----- Mount / switch_root -----
CONFIG_MOUNT=y
CONFIG_FEATURE_MOUNT_FLAGS=y
CONFIG_FEATURE_MOUNT_HELPERS=n
CONFIG_UMOUNT=y
CONFIG_SWITCH_ROOT=y
CONFIG_PIVOT_ROOT=y

# ----- Process management -----
CONFIG_PS=y
CONFIG_KILL=y
CONFIG_KILLALL=y
CONFIG_SLEEP=y

# ----- Privilege dropping (Phase 41) -----
# su: switch user; root can su to nura without a password.
CONFIG_SU=y
CONFIG_FEATURE_SU_SYSLOG=n
CONFIG_FEATURE_SU_CHECKS_SHELLS=n

# ----- Networking -----
CONFIG_IP=y
CONFIG_PING=y
CONFIG_UDHCPC=y
CONFIG_FEATURE_UDHCPC_ARPING=n
CONFIG_WGET=n
CONFIG_NETSTAT=n
CONFIG_IFCONFIG=n

# ----- Misc -----
CONFIG_UNAME=y
CONFIG_DATE=y
CONFIG_ENV=y
CONFIG_DMESG=y
CONFIG_SYSCTL=n

# ----- Console/VT tools (disabled: NuraOS is headless) -----
# These applets need linux/kd.h or linux/vt.h which are not available
# through musl-gcc's include path; they serve no purpose in a QEMU VM.
CONFIG_CHVT=n
CONFIG_DEALLOCVT=n
CONFIG_FGCONSOLE=n
CONFIG_KBD_MODE=n
CONFIG_LOADFONT=n
CONFIG_LOADKMAP=n
CONFIG_OPENVT=n
CONFIG_RESET=n
CONFIG_RESIZE=n
CONFIG_SETCONSOLE=n
CONFIG_SETFONT=n
CONFIG_SETKEYCODES=n
CONFIG_SETLOGCONS=n
CONFIG_SHOWKEY=n

# ----- Disabled applets (keep the binary small) -----
CONFIG_GZIP=n
CONFIG_TAR=n
CONFIG_AWK=n
CONFIG_VI=n
CONFIG_FTP=n
CONFIG_TELNET=n
CONFIG_HTTPD=n
CONFIG_CROND=n
CONFIG_CRONTAB=n
CONFIG_DD=n
CONFIG_WATCH=n
CONFIG_STTY=n
# nandwrite needs mtd/mtd-user.h (not in musl include tree; embedded flash N/A)
CONFIG_NANDWRITE=n
# tc uses CBQ traffic-control structs removed from modern kernel headers
CONFIG_TC=n
