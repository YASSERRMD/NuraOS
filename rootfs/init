#!/bin/sh
# /init -- PID 1 bootstrap for NuraOS initramfs.
# This script is executed by the kernel directly after mounting the initramfs.
# It sets up the essential mounts, brings up the network, mounts /data,
# then hands control to the supervisor (or drops to a shell in recovery mode).

# Redirect stderr to console early so errors are visible.
exec 2>/dev/console

log() { echo "[init] $*"; }
warn() { echo "[init] WARNING: $*" >&2; }
die()  { echo "[init] FATAL: $*" >&2; exec sh; }

# Read kernel cmdline for flags.
read -r CMDLINE < /proc/cmdline 2>/dev/null || CMDLINE=""
has_flag() { echo "${CMDLINE}" | grep -qw "$1"; }

log "NuraOS init starting"

# ----- Essential virtual filesystems -----
log "mounting proc ..."
mount -t proc proc /proc || die "failed to mount /proc"

log "mounting sysfs ..."
mount -t sysfs sysfs /sys || die "failed to mount /sys"

log "mounting devtmpfs ..."
mount -t devtmpfs devtmpfs /dev || die "failed to mount /dev"

# Create a minimal set of device nodes in case devtmpfs is not available.
[ -c /dev/console ] || mknod -m 600 /dev/console c 5 1
[ -c /dev/null ]    || mknod -m 666 /dev/null c 1 3
[ -c /dev/zero ]    || mknod -m 666 /dev/zero c 1 5
[ -c /dev/urandom ] || mknod -m 444 /dev/urandom c 1 9

log "mounting cgroup2 on /sys/fs/cgroup ..."
mkdir -p /sys/fs/cgroup
mount -t cgroup2 -o nosuid,nodev,noexec none /sys/fs/cgroup 2>/dev/null || \
    warn "cgroup2 mount failed; resource limits will be inactive"
# Enable cpu, memory, and io controllers so the manager can set per-service limits.
printf "+cpu +memory +io" > /sys/fs/cgroup/cgroup.subtree_control 2>/dev/null || true

log "mounting tmpfs on /tmp ..."
mount -t tmpfs tmpfs /tmp

log "mounting tmpfs on /run ..."
mkdir -p /run
mount -t tmpfs -o mode=755,nosuid,nodev tmpfs /run

log "mounting tmpfs on /var ..."
mkdir -p /var
mount -t tmpfs -o mode=755,nosuid,nodev tmpfs /var
# FHS compat: /var/run is a symlink to /run.
ln -sf /run /var/run

# ----- Recovery mode -----
if has_flag "nura.recovery=1"; then
    log "recovery flag set; dropping to emergency shell"
    log "exit the shell to continue the boot sequence"
    exec sh
fi

# ----- Network bringup -----
log "bringing up loopback ..."
ip link set lo up 2>/dev/null || warn "failed to bring up loopback"

log "bringing up eth0 (DHCP) ..."
UDHCPC_SCRIPT=/etc/udhcpc/default.script
ip link set eth0 up 2>/dev/null && \
    udhcpc -i eth0 -q -n -t 5 \
        ${UDHCPC_SCRIPT:+-s "${UDHCPC_SCRIPT}"} 2>/dev/null && \
    log "eth0: DHCP OK" || warn "eth0 DHCP failed; continuing without network"

# Write a minimal resolv.conf if DHCP did not create one.
[ -f /etc/resolv.conf ] || printf 'nameserver 10.0.2.3\nnameserver 8.8.8.8\n' > /etc/resolv.conf

# ----- /data persistent partition -----
DATA_DEV=""
# Look for the first virtio block device that is not the root.
for dev in /dev/vda /dev/vdb /dev/sda; do
    [ -b "${dev}" ] && DATA_DEV="${dev}" && break
done

DATA_MOUNT_OPTS="data=ordered,barrier=1,noatime"

# ----- Optional LUKS encryption -----
# Enable with kernel cmdline flag: nura.data.luks=1
# Requires cryptsetup in the initramfs (install via scripts/build-initramfs.sh).
if has_flag "nura.data.luks=1" && [ -n "${DATA_DEV}" ]; then
    log "LUKS encryption requested for /data (${DATA_DEV})"

    if ! command -v cryptsetup >/dev/null 2>&1; then
        die "LUKS requested but cryptsetup not found in initramfs; rebuild with LUKS support"
    fi

    LUKS_OPENED=0

    # Key source 1: 4096-byte key file from a secondary block device (/dev/vdb or /dev/sdb).
    LUKS_KEYDEV=""
    for _kdev in /dev/vdb /dev/sdb /dev/sdc; do
        [ -b "${_kdev}" ] && LUKS_KEYDEV="${_kdev}" && break
    done

    if [ -n "${LUKS_KEYDEV}" ]; then
        log "LUKS: trying key file from ${LUKS_KEYDEV} ..."
        if cryptsetup luksOpen --key-file "${LUKS_KEYDEV}" \
                --keyfile-size 4096 "${DATA_DEV}" nura-data 2>/dev/null; then
            log "LUKS: opened with key file from ${LUKS_KEYDEV}"
            LUKS_OPENED=1
        else
            warn "LUKS: key file on ${LUKS_KEYDEV} did not match"
        fi
    fi

    # Key source 2: passphrase entered on the serial console.
    if [ "${LUKS_OPENED}" -eq 0 ]; then
        log "LUKS: no key device found; prompting for passphrase on console"
        stty -echo 2>/dev/null
        printf "NuraOS /data passphrase: " > /dev/console
        read -r LUKS_PASS < /dev/console
        stty echo 2>/dev/null
        printf "\n" > /dev/console
        if printf "%s" "${LUKS_PASS}" | \
                cryptsetup luksOpen --key-file - "${DATA_DEV}" nura-data 2>/dev/null; then
            log "LUKS: opened with passphrase"
            LUKS_OPENED=1
        else
            warn "LUKS: passphrase did not match"
        fi
        unset LUKS_PASS
    fi

    if [ "${LUKS_OPENED}" -eq 0 ]; then
        log "LUKS: all key sources exhausted; /data partition locked"
        log "LUKS: boot with nura.recovery=1 to access a recovery shell"
        log "LUKS: failing closed -- no persistent data will be accessible"
        exec sh
    fi

    # Replace DATA_DEV with the unlocked mapper device for fsck and mount.
    DATA_DEV=/dev/mapper/nura-data
fi

if [ -n "${DATA_DEV}" ]; then
    # Run fsck before mounting; bound it to 30 seconds.
    log "fsck ${DATA_DEV} ..."
    if timeout 30 e2fsck -p "${DATA_DEV}" >/dev/console 2>&1; then
        FSCK_RC=$?
    else
        FSCK_RC=$?
    fi

    if [ "${FSCK_RC}" -le 1 ]; then
        # 0 = filesystem clean, 1 = errors corrected -- safe to mount rw.
        log "mounting /data from ${DATA_DEV} (${DATA_MOUNT_OPTS}) ..."
        if mount -t ext4 -o "${DATA_MOUNT_OPTS}" "${DATA_DEV}" /data 2>/dev/null; then
            log "/data mounted (durable)"
            mkdir -p /data/models /data/logs /data/sessions /data/etc /data/journal
        else
            warn "failed to mount ${DATA_DEV}; /data will be tmpfs"
            mount -t tmpfs tmpfs /data
            mkdir -p /data/models /data/logs /data/sessions /data/etc /data/journal
        fi
    else
        # fsck could not repair; mount read-only for recovery inspection.
        warn "fsck returned ${FSCK_RC} on ${DATA_DEV}; mounting read-only for recovery"
        if ! mount -t ext4 -o ro "${DATA_DEV}" /data 2>/dev/null; then
            warn "read-only mount also failed; /data will be tmpfs"
            mount -t tmpfs tmpfs /data
        fi
        mkdir -p /data/models /data/logs /data/sessions /data/etc /data/journal 2>/dev/null || true
    fi
else
    warn "no /data block device found; /data will be tmpfs (no persistence)"
    mount -t tmpfs tmpfs /data
    mkdir -p /data/models /data/logs /data/sessions /data/etc /data/journal
fi

# ----- Bind persistent paths from /data -----
# resolv.conf: restore from /data on boot; save current value there for next boot.
if [ -f /data/etc/resolv.conf ]; then
    mount --bind /data/etc/resolv.conf /etc/resolv.conf 2>/dev/null && \
        log "resolv.conf: restored from /data/etc/resolv.conf" || \
        warn "resolv.conf: bind mount failed; using in-memory copy"
else
    # Save current resolv.conf so it survives the next reboot.
    cp /etc/resolv.conf /data/etc/resolv.conf 2>/dev/null || true
fi

# ----- Least-privilege setup -----
# Per-service ownership: each service owns only the dirs it writes to.
# UIDs: nura-mgr=100, nura=1000, nura-gw=1001, llama=1002
# /run: root-owned; service manager creates sockets there.
chmod 755 /run 2>/dev/null || true
# /data/journal: manager (root) writes here on behalf of all services.
chmod 755 /data/journal 2>/dev/null || true
# /data/logs and /data/sessions: owned by nura-agent (uid 1000).
chown 1000:1000 /data/logs /data/sessions 2>/dev/null || \
    warn "chown data dirs failed (users may not exist yet)"
chmod 750 /data/logs /data/sessions 2>/dev/null || true
# /data/models: root owns, llama group readable (gid 1002).
chown 0:1002 /data/models 2>/dev/null || true
chmod 750 /data/models 2>/dev/null || true

# ----- Optional network self-test (off by default) -----
if has_flag "nura.nettest=1"; then
    GW=$(ip route show default 2>/dev/null | awk '/default/ {print $3; exit}')
    if [ -n "${GW}" ]; then
        log "network self-test: pinging gateway ${GW} ..."
        ping -c 1 -W 2 "${GW}" >/dev/null 2>&1 && \
            log "network self-test: PASS" || \
            warn "network self-test: FAIL (no route to gateway)"
    else
        warn "network self-test: no default gateway found"
    fi
fi

# ----- Log mount layout -----
log "mount layout:"
log "  / (initramfs)  -- read-only by convention; OS binaries not written at runtime"
log "  /run  tmpfs    -- ephemeral: Unix sockets, PIDs (reset on reboot)"
log "  /tmp  tmpfs    -- ephemeral: scratch space (reset on reboot)"
log "  /var  tmpfs    -- ephemeral: FHS runtime state (reset on reboot)"
log "  /data ext4     -- persistent: models, journal, sessions, config, secrets"

# ----- Hand off to supervisor -----
SUPERVISOR=/sbin/supervisor
if [ -x "${SUPERVISOR}" ]; then
    log "exec ${SUPERVISOR}"
    exec "${SUPERVISOR}"
else
    # Phase 07: supervisor not yet present; drop to a shell for interactive use.
    log "supervisor not found at ${SUPERVISOR}; dropping to BusyBox shell"
    log "Type 'poweroff' or 'halt' to exit."
    exec sh
fi
