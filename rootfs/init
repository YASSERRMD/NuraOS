#!/bin/sh
# /init -- PID 1 bootstrap for NuraOS initramfs.
# This script is executed by the kernel directly after mounting the initramfs.
# It sets up the essential mounts, brings up the network, mounts /data,
# then hands control to the supervisor (or drops to a shell in recovery mode).

# Redirect stderr to console early so errors are visible.
exec 2>/dev/console

log() { echo "[init] $*"; }
warn() { echo "[init] WARNING: $*" >&2; }
die()  { echo "[init] FATAL: $*" >&2; exec sh; }

# Read kernel cmdline for flags.
read -r CMDLINE < /proc/cmdline 2>/dev/null || CMDLINE=""
has_flag() { echo "${CMDLINE}" | grep -qw "$1"; }

log "NuraOS init starting"

# ----- Essential virtual filesystems -----
log "mounting proc ..."
mount -t proc proc /proc || die "failed to mount /proc"

log "mounting sysfs ..."
mount -t sysfs sysfs /sys || die "failed to mount /sys"

log "mounting devtmpfs ..."
mount -t devtmpfs devtmpfs /dev || die "failed to mount /dev"

# Create a minimal set of device nodes in case devtmpfs is not available.
[ -c /dev/console ] || mknod -m 600 /dev/console c 5 1
[ -c /dev/null ]    || mknod -m 666 /dev/null c 1 3
[ -c /dev/zero ]    || mknod -m 666 /dev/zero c 1 5
[ -c /dev/urandom ] || mknod -m 444 /dev/urandom c 1 9

# ----- Early entropy seeding via virtio-rng -----
# Feed 512 bytes from the hardware RNG into the kernel pool. This seeds the
# CSPRNG before any crypto operations, including TLS in Go services.
# virtio-rng is enabled with CONFIG_HW_RANDOM_VIRTIO=y and exposed as /dev/hwrng.
if [ -c /dev/hwrng ]; then
    if dd if=/dev/hwrng of=/dev/urandom bs=512 count=1 2>/dev/null; then
        log "entropy: seeded kernel pool from virtio-rng (/dev/hwrng)"
    else
        warn "entropy: virtio-rng read failed; using accumulated entropy"
    fi
else
    warn "entropy: /dev/hwrng not present (CONFIG_HW_RANDOM_VIRTIO not set or no virtio-rng device)"
fi
_avail=$(cat /proc/sys/kernel/random/entropy_avail 2>/dev/null || echo "?")
log "entropy: ${_avail} bits available after early seed"

# ----- mdev device manager -----
# Register mdev as the kernel hotplug helper, then scan /sys to apply
# permissions from /etc/mdev.conf and create symlinks for new devices.
if command -v mdev >/dev/null 2>&1; then
    echo /sbin/mdev > /proc/sys/kernel/hotplug 2>/dev/null || \
        warn "failed to register mdev as hotplug helper"
    mdev -s 2>/dev/null && log "mdev: initial /dev scan complete" || \
        warn "mdev -s failed; permissions may not match /etc/mdev.conf"
else
    warn "mdev not found; hotplug support disabled"
fi

# Ensure devpts is mounted for PTY support.
mkdir -p /dev/pts
mount -t devpts -o gid=5,mode=620 devpts /dev/pts 2>/dev/null || \
    warn "devpts mount failed"

log "mounting cgroup2 on /sys/fs/cgroup ..."
mkdir -p /sys/fs/cgroup
mount -t cgroup2 -o nosuid,nodev,noexec none /sys/fs/cgroup 2>/dev/null || \
    warn "cgroup2 mount failed; resource limits will be inactive"
# Enable cpu, memory, and io controllers so the manager can set per-service limits.
printf "+cpu +memory +io" > /sys/fs/cgroup/cgroup.subtree_control 2>/dev/null || true

log "mounting tmpfs on /tmp ..."
mount -t tmpfs tmpfs /tmp

log "mounting tmpfs on /run ..."
mkdir -p /run
mount -t tmpfs -o mode=755,nosuid,nodev tmpfs /run

log "mounting tmpfs on /var ..."
mkdir -p /var
mount -t tmpfs -o mode=755,nosuid,nodev tmpfs /var
# FHS compat: /var/run is a symlink to /run.
ln -sf /run /var/run

# ----- CPU frequency profile -----
# Apply the governor and compute inference thread count before any services
# start. The thread count is written to /run/nura-cpu-threads where the
# llama-server-wrapper reads it at launch time.
if [ -x /sbin/nura-cpu-apply ]; then
    log "$(nura-cpu-apply)"
else
    warn "nura-cpu-apply not found; using default CPU governor"
fi

# ----- Early (pre-data) recovery -----
# nura.recovery=early drops to a minimal BusyBox shell immediately, before
# network or /data are touched. Use when /data itself is unresponsive or when
# the block device is inaccessible. For normal recovery tools (fsck, rollback,
# factory-reset) use nura.recovery=1 instead.
if has_flag "nura.recovery=early"; then
    log "EARLY RECOVERY: dropping to minimal shell (no network, no /data mount)"
    log "exit the shell to initiate a reboot"
    sh
    sync; reboot -f 2>/dev/null || halt -f 2>/dev/null || exec sh
fi

# ----- Network bringup (skipped in recovery mode) -----
# Recovery mode deliberately does NOT start networking to limit attack surface
# and prevent the agent from making outbound connections while the system may
# be in an inconsistent state.
if ! has_flag "nura.recovery=1"; then
    log "bringing up loopback ..."
    ip link set lo up 2>/dev/null || warn "failed to bring up loopback"

    log "bringing up eth0 (DHCP) ..."
    UDHCPC_SCRIPT=/etc/udhcpc/default.script
    ip link set eth0 up 2>/dev/null && \
        udhcpc -i eth0 -q -n -t 5 \
            ${UDHCPC_SCRIPT:+-s "${UDHCPC_SCRIPT}"} 2>/dev/null && \
        log "eth0: DHCP OK" || warn "eth0 DHCP failed; continuing without network"

    # Write a minimal resolv.conf if DHCP did not create one.
    # QEMU user-mode NAT provides a DNS forwarder at 10.0.2.3; 1.1.1.1 is the
    # secondary. On a private LAN, the DHCP-provided nameserver is preferred.
    if [ ! -f /etc/resolv.conf ] || [ ! -s /etc/resolv.conf ]; then
        printf 'nameserver 10.0.2.3\nnameserver 1.1.1.1\n' > /etc/resolv.conf
        log "DNS: wrote fallback resolv.conf (DHCP did not provide one)"
    fi
    log "DNS: nameservers: $(grep '^nameserver' /etc/resolv.conf | awk '{print $2}' | tr '\n' ' ')"

    # ----- Firewall (nftables) -----
    if [ -x /sbin/nura-firewall-apply ]; then
        log "$(nura-firewall-apply)"
    else
        warn "nura-firewall-apply not found; system is UNPROTECTED"
    fi
else
    log "recovery mode: skipping network bringup and firewall"
fi

# ----- /data persistent partition -----
# Determine the data block device.
#
# Detection order (first match wins):
#   1. nura.data.dev=<name> on the kernel cmdline (explicit, deterministic)
#   2. /dev/vdb  -- second virtio block device (QEMU default layout)
#   3. /dev/sda  -- first SCSI disk (fallback for non-virtio configs)
#   4. /dev/vda  -- first virtio disk (single-disk QEMU, last resort)
#
# The resolved device path is written to /run/nura-data-dev so that the
# hotplug-block mdev script can mount /data when the disk appears late.
DATA_DEV=""

# Priority 1: explicit cmdline override.
CMDLINE_DEV=$(echo "${CMDLINE}" | grep -oE 'nura\.data\.dev=[^ ]+' | \
              sed 's/nura\.data\.dev=//' | head -1)
if [ -n "${CMDLINE_DEV}" ]; then
    case "${CMDLINE_DEV}" in
    /dev/*) DATA_DEV="${CMDLINE_DEV}" ;;
    *)      DATA_DEV="/dev/${CMDLINE_DEV}" ;;
    esac
    log "data device: using cmdline override ${DATA_DEV}"
fi

# Priority 2-4: automatic detection.
if [ -z "${DATA_DEV}" ]; then
    for dev in /dev/vdb /dev/sda /dev/vda; do
        [ -b "${dev}" ] && DATA_DEV="${dev}" && break
    done
fi

# Save resolved device for the hotplug-block mdev script.
if [ -n "${DATA_DEV}" ]; then
    printf '%s' "${DATA_DEV}" > /run/nura-data-dev
    # Create deterministic /dev/nura-data symlink for consistent reference.
    ln -sf "${DATA_DEV}" /dev/nura-data 2>/dev/null && \
        log "device alias: /dev/nura-data -> ${DATA_DEV}"
fi

DATA_MOUNT_OPTS="data=ordered,barrier=1,noatime"

# ----- Optional LUKS encryption -----
# Enable with kernel cmdline flag: nura.data.luks=1
# Requires cryptsetup in the initramfs (install via scripts/build-initramfs.sh).
if has_flag "nura.data.luks=1" && [ -n "${DATA_DEV}" ]; then
    log "LUKS encryption requested for /data (${DATA_DEV})"

    if ! command -v cryptsetup >/dev/null 2>&1; then
        die "LUKS requested but cryptsetup not found in initramfs; rebuild with LUKS support"
    fi

    LUKS_OPENED=0

    # Key source 1: 4096-byte key file from a secondary block device (/dev/vdb or /dev/sdb).
    LUKS_KEYDEV=""
    for _kdev in /dev/vdb /dev/sdb /dev/sdc; do
        [ -b "${_kdev}" ] && LUKS_KEYDEV="${_kdev}" && break
    done

    if [ -n "${LUKS_KEYDEV}" ]; then
        log "LUKS: trying key file from ${LUKS_KEYDEV} ..."
        if cryptsetup luksOpen --key-file "${LUKS_KEYDEV}" \
                --keyfile-size 4096 "${DATA_DEV}" nura-data 2>/dev/null; then
            log "LUKS: opened with key file from ${LUKS_KEYDEV}"
            LUKS_OPENED=1
        else
            warn "LUKS: key file on ${LUKS_KEYDEV} did not match"
        fi
    fi

    # Key source 2: passphrase entered on the serial console.
    if [ "${LUKS_OPENED}" -eq 0 ]; then
        log "LUKS: no key device found; prompting for passphrase on console"
        stty -echo 2>/dev/null
        printf "NuraOS /data passphrase: " > /dev/console
        read -r LUKS_PASS < /dev/console
        stty echo 2>/dev/null
        printf "\n" > /dev/console
        if printf "%s" "${LUKS_PASS}" | \
                cryptsetup luksOpen --key-file - "${DATA_DEV}" nura-data 2>/dev/null; then
            log "LUKS: opened with passphrase"
            LUKS_OPENED=1
        else
            warn "LUKS: passphrase did not match"
        fi
        unset LUKS_PASS
    fi

    if [ "${LUKS_OPENED}" -eq 0 ]; then
        log "LUKS: all key sources exhausted; /data partition locked"
        log "LUKS: boot with nura.recovery=1 to access a recovery shell"
        log "LUKS: failing closed -- no persistent data will be accessible"
        exec sh
    fi

    # Replace DATA_DEV with the unlocked mapper device for fsck and mount.
    DATA_DEV=/dev/mapper/nura-data
fi

if [ -n "${DATA_DEV}" ]; then
    # Run fsck before mounting; bound it to 30 seconds.
    log "fsck ${DATA_DEV} ..."
    if timeout 30 e2fsck -p "${DATA_DEV}" >/dev/console 2>&1; then
        FSCK_RC=$?
    else
        FSCK_RC=$?
    fi

    if [ "${FSCK_RC}" -le 1 ]; then
        # 0 = filesystem clean, 1 = errors corrected -- safe to mount rw.
        log "mounting /data from ${DATA_DEV} (${DATA_MOUNT_OPTS}) ..."
        if mount -t ext4 -o "${DATA_MOUNT_OPTS}" "${DATA_DEV}" /data 2>/dev/null; then
            log "/data mounted (durable)"
            mkdir -p /data/models /data/logs /data/sessions /data/etc /data/journal
        else
            warn "failed to mount ${DATA_DEV}; /data will be tmpfs"
            mount -t tmpfs tmpfs /data
            mkdir -p /data/models /data/logs /data/sessions /data/etc /data/journal
        fi
    else
        # fsck could not repair; mount read-only for recovery inspection.
        warn "fsck returned ${FSCK_RC} on ${DATA_DEV}; mounting read-only for recovery"
        if ! mount -t ext4 -o ro "${DATA_DEV}" /data 2>/dev/null; then
            warn "read-only mount also failed; /data will be tmpfs"
            mount -t tmpfs tmpfs /data
        fi
        mkdir -p /data/models /data/logs /data/sessions /data/etc /data/journal 2>/dev/null || true
    fi
else
    warn "no /data block device found; /data will be tmpfs (no persistence)"
    mount -t tmpfs tmpfs /data
    mkdir -p /data/models /data/logs /data/sessions /data/etc /data/journal
fi

# ----- Seed file: persist entropy across reboots -----
# Load the persisted random seed from /data (if available) and immediately
# refresh it so that each boot uses a unique seed. A stolen disk image cannot
# replay a previous session's entropy state.
SEED_FILE=/data/etc/random.seed
if [ -f "${SEED_FILE}" ] && [ -s "${SEED_FILE}" ]; then
    if dd if="${SEED_FILE}" of=/dev/urandom bs=512 count=2 2>/dev/null; then
        log "entropy: loaded persisted seed from ${SEED_FILE}"
    else
        warn "entropy: failed to load persisted seed from ${SEED_FILE}"
    fi
fi
# Refresh seed for next boot with fresh random bytes (not a copy of the loaded seed).
if dd if=/dev/urandom bs=512 count=2 2>/dev/null > "${SEED_FILE}.new" && \
   chmod 600 "${SEED_FILE}.new" && \
   mv "${SEED_FILE}.new" "${SEED_FILE}"; then
    log "entropy: seed refreshed at ${SEED_FILE}"
else
    warn "entropy: seed refresh failed (${SEED_FILE})"
    rm -f "${SEED_FILE}.new" 2>/dev/null
fi
_avail=$(cat /proc/sys/kernel/random/entropy_avail 2>/dev/null || echo "?")
log "entropy: ${_avail} bits available after seed file load"

# ----- Bind persistent paths from /data -----
# resolv.conf: restore from /data on boot; save current value there for next boot.
if [ -f /data/etc/resolv.conf ]; then
    mount --bind /data/etc/resolv.conf /etc/resolv.conf 2>/dev/null && \
        log "resolv.conf: restored from /data/etc/resolv.conf" || \
        warn "resolv.conf: bind mount failed; using in-memory copy"
else
    # Save current resolv.conf so it survives the next reboot.
    cp /etc/resolv.conf /data/etc/resolv.conf 2>/dev/null || true
fi

# ----- Boot integrity verification -----
# Check SHA-256 hashes of key files against /data/etc/boot-hashes (sha256sum
# compatible format). A signed boot manifest at /data/etc/boot-manifest.json
# ties this hash list to an Ed25519 key; the Go runtime performs the full
# signature check. The shell check here is the first line of defence.
#
# Fail-closed: a hash mismatch drops to a recovery shell before the supervisor
# is started. To bypass verification, boot with nura.recovery=1 (the recovery
# check above fires first and skips the rest of init entirely).
BOOT_HASHES=/data/etc/boot-hashes
INTEGRITY_STATUS=/run/nura-integrity-status
_INOW=$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date +%Y-%m-%dT%H:%M:%SZ)

if [ -f "${BOOT_HASHES}" ]; then
    log "integrity: verifying boot hashes from ${BOOT_HASHES} ..."
    if sha256sum -c "${BOOT_HASHES}" >/dev/null 2>&1; then
        log "integrity: PASS -- all entries verified"
        printf '{"result":"pass","timestamp":"%s"}\n' "${_INOW}" > "${INTEGRITY_STATUS}"
    else
        log "integrity: FAIL -- SHA-256 mismatch"
        printf '{"result":"fail","timestamp":"%s","detail":"sha256 mismatch in boot-hashes"}\n' \
            "${_INOW}" > "${INTEGRITY_STATUS}"
        warn "boot integrity check FAILED; dropping to recovery shell"
        warn "inspect: sha256sum -c ${BOOT_HASHES}"
        warn "to skip: reboot with nura.recovery=1 on the kernel cmdline"
        exec sh
    fi
else
    log "integrity: no boot-hashes at ${BOOT_HASHES}; verification skipped"
    printf '{"result":"skipped","timestamp":"%s"}\n' "${_INOW}" > "${INTEGRITY_STATUS}"
fi

# ----- Full recovery console (nura.recovery=1) -----
# Launched after /data is mounted so rollback, fsck, and factory-reset tools
# have access to persistent state. Network is already skipped above.
if has_flag "nura.recovery=1"; then
    RECOVERY_CONSOLE=/sbin/nura-recovery
    if [ -x "${RECOVERY_CONSOLE}" ]; then
        log "recovery mode: launching recovery console"
        "${RECOVERY_CONSOLE}"
    else
        log "recovery mode: ${RECOVERY_CONSOLE} not found; dropping to shell"
        log "type 'exit' to reboot"
        sh
    fi
    sync
    reboot -f 2>/dev/null || halt -f 2>/dev/null || exec sh
fi

# ----- Least-privilege setup -----
# Per-service ownership: each service owns only the dirs it writes to.
# UIDs: nura-mgr=100, nura=1000, nura-gw=1001, llama=1002
# /run: root-owned; service manager creates sockets there.
chmod 755 /run 2>/dev/null || true
# /data/journal: manager (root) writes here on behalf of all services.
chmod 755 /data/journal 2>/dev/null || true
# /data/logs and /data/sessions: owned by nura-agent (uid 1000).
chown 1000:1000 /data/logs /data/sessions 2>/dev/null || \
    warn "chown data dirs failed (users may not exist yet)"
chmod 750 /data/logs /data/sessions 2>/dev/null || true
# /data/models: root owns, llama group readable (gid 1002).
chown 0:1002 /data/models 2>/dev/null || true
chmod 750 /data/models 2>/dev/null || true

# ----- Optional network self-test (off by default) -----
if has_flag "nura.nettest=1"; then
    GW=$(ip route show default 2>/dev/null | awk '/default/ {print $3; exit}')
    if [ -n "${GW}" ]; then
        log "network self-test: pinging gateway ${GW} ..."
        ping -c 1 -W 2 "${GW}" >/dev/null 2>&1 && \
            log "network self-test: PASS" || \
            warn "network self-test: FAIL (no route to gateway)"
    else
        warn "network self-test: no default gateway found"
    fi
fi

# ----- Log mount layout -----
log "mount layout:"
log "  / (initramfs)  -- read-only by convention; OS binaries not written at runtime"
log "  /run  tmpfs    -- ephemeral: Unix sockets, PIDs (reset on reboot)"
log "  /tmp  tmpfs    -- ephemeral: scratch space (reset on reboot)"
log "  /var  tmpfs    -- ephemeral: FHS runtime state (reset on reboot)"
log "  /data ext4     -- persistent: models, journal, sessions, config, secrets"

# ----- Hand off to supervisor -----
SUPERVISOR=/sbin/supervisor
if [ -x "${SUPERVISOR}" ]; then
    log "exec ${SUPERVISOR}"
    exec "${SUPERVISOR}"
else
    # Phase 07: supervisor not yet present; drop to a shell for interactive use.
    log "supervisor not found at ${SUPERVISOR}; dropping to BusyBox shell"
    log "Type 'poweroff' or 'halt' to exit."
    exec sh
fi
