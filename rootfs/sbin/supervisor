#!/bin/sh
# /sbin/supervisor -- NuraOS PID-1 init wrapper.
#
# Phase 56+: delegates service management to nura-manager, which reads
# declarative TOML unit files from /etc/nura/services/.
#
# Recovery mode: nura.recovery=1 on the kernel cmdline drops to a shell
# without starting any services.

LOG_FILE=/data/logs/boot.log
STAGE_FILE=/tmp/supervisor.stage

log() {
    TS=$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || echo "")
    MSG="[supervisor] ${TS} $*"
    echo "${MSG}"
    echo "${MSG}" >> "${LOG_FILE}" 2>/dev/null || true
}

stage() {
    log "STAGE: $*"
    echo "$*" > "${STAGE_FILE}"
}

die() {
    log "FATAL: $*"
    log "dropping to emergency shell"
    exec sh
}

read -r CMDLINE < /proc/cmdline 2>/dev/null || CMDLINE=""
has_flag() { echo "${CMDLINE}" | grep -qw "$1"; }

mkdir -p /data/logs 2>/dev/null || true
rm -f "${STAGE_FILE}" 2>/dev/null || true

log "supervisor starting (PID $$)"

if has_flag "nura.recovery=1"; then
    log "recovery mode: skipping service start"
    stage "recovery"
    log "Type 'poweroff' or 'halt' to exit."
    exec sh
fi

stage "service-manager"

if [ -x /sbin/nura-manager ]; then
    log "delegating to nura-manager"
    exec /sbin/nura-manager run
else
    log "nura-manager not found; falling back to legacy supervisor"
    # Legacy fallback preserved for early boot phases (pre-56 images).
    exec /sbin/supervisor-legacy
fi
